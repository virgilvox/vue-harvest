{
  "name": "vue-harvest",
  "version": "0.0.2",
  "description": "Extract reusable component libraries and design tokens from any Vue application",
  "type": "module",
  "license": "MIT",
  "author": "virgilvox",
  "repository": {
    "type": "git",
    "url": "https://github.com/virgilvox/vue-harvest"
  },
  "keywords": [
    "vue",
    "components",
    "extraction",
    "design-system",
    "design-tokens",
    "mcp",
    "cli",
    "shadcn",
    "component-library"
  ],
  "bin": {
    "vue-harvest": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.0",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "es-module-lexer": "^1.6.0",
    "fast-glob": "^3.3.0",
    "pathe": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
